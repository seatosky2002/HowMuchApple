# App
APP_NAME="HowMuch API"
DEBUG=false

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=howmuch
POSTGRES_USER=howmuch
POSTGRES_PASSWORD=yourpassword

# JWT
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# Cookie (set COOKIE_SECURE=true and COOKIE_DOMAIN in production)
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=your@gmail.com
FROM_NAME=HowMuch

# OAuth — Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/kakao/callback

# OAuth — Apple
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/apple/callback

# Frontend
FRONTEND_URL=http://localhost:3000

# Scheduler (cron)
CRAWLER_SCHEDULE="0 6 * * *"
ALERT_SCHEDULE="30 6 * * *"
